//  PROBLEM 01: THE IF CONDITION 
//  Task: Verify if a user is eligible to vote

#include <iostream>
using namespace std;

int main() {
    int age;
    cin >> age;
    // if condition 
    if(age >= 18) { 
        cout << "Eligible For vote";
    } 
    return 0;
}

//  PROBLEM 02: THE IF-ELSE BRANCH 
//  Task: Handle both eligible and ineligible cases

#include <iostream>
using namespace std;

int main() {
    int age;
    cin >> age;
    // if condition 
    if(18<=age<=79) {
        cout << "Eligible For vote - Working Citizen";
    }
    //else if condition 
    else if(80<=age<=100){
        cout<< "Eligible to vote - Senior Citizen";
    }
    else if(age>100){
        cout<< "Eligible to vote - Old aged";
    }
    //else  condition
    else if(0<age<=17){
        cout << "Not Eligible For vote";
    }
    else{
        cout<<"Invalid input";
    }
    return 0;
}

//  PROBLEM 03: NESTED IF-ELSE LOGIC 
//  Task: Take a percentage input and designate a grade to it

#include <iostream>
using namespace std;

int main() {
    int per;
    cin >> per;
    
    if(per >= 60) {
        if (per >= 70) {
            if(per >= 80){
                if(per >= 90){
                    cout<<"A"<<endl;
                }else{
                    cout<<"B"<<endl;
                } 
            }else {
                cout<<"C"<<endl;
                }
        }else {
            cout<<"D"<<endl;
        }
    }else {
        cout<<"F"<<endl;
    }
    return 0;
}

