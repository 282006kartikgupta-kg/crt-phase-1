//  PROBLEM 09: COUNTDOWN TIMER
//  Task: take an input and countdown till one 

#include<iostream>
using namespace std;

int main(){
int n;
cout<<"Enter number: ";
cin>>n;

cout<<"Blastoff!!!"<<endl;

for(int i = n; i >= 1; i--){
    cout<< i <<endl;
}
return 0;
}

//  PROBLEM 10: ATM PIN RETRY
//  Task: Check atm pin for 4 tries

#include<iostream>
using namespace std;

int main(){
int pin = 1020;

int attempts = 0;

do{
    int atm_pin;
    cout<<"Enter ATM Pin : ";
    cin>>atm_pin;
    if(atm_pin == pin){
        cout<<"Access Granted";
        break;
    } else if (attempts <= 3){
        cout<<"Try Again"<<endl;
        attempts++;
    } else {
        cout<<"Card Blocked!!!";
    }
}while(attempts < 4);

return 0;
}