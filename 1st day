//  PROBLEM 05: Arithmetic operations
//  Task: get number and operator sign

#include<iostream>
using namespace std;

int main(){
char sign;
cout<<"Enter arithmetic operator: ";
cin>>sign;

int num1,num2;
cout<<"Enter Numbers: "<<endl;
cin>>num1>>num2;
int result = 0;

switch (sign)
{
case '+':
    result = num1 + num2;
    cout<<"num1 + num2 = "<<result;
    break;
case '-':
    result = num1 - num2;
    cout<<"num1 - num2 = "<<result;
    break;
case '*':
    result = num1 * num2;
    cout<<"num1 * num2 = "<<result;
    break;
case '/':
    if(num2!=0){
    result = num1 / num2;
    cout<<"num1 / num2 = "<<result;
    break;
    }

default:
    break;
}


return 0;
}

//  PROBLEM 06: THE SWAP LOGIC 
//  Task: Exchange values using a temporary variable

#include<iostream>
using namespace std;

int main(){
int a,b;
cout<<"Enter numbers: "<<endl;
cin>>a>>b;

int temp;
temp = a;
a = b;
b = temp;

cout<<a<<" "<<b;
return 0;
}

