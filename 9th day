// PROBLEM 03 - Reverse Array
// Task - print the reverse of the array

#include<iostream>
using namespace std;
class Reverse{
    public:
    void Reverse_Array(int arr[], int n){
    for(int i = 0; i<n; i++){
        cout<<arr[i]<<" ";
        }
    cout<<endl;
        int start = 0;
        int end = n - 1;
        while (start<end){
            int temp = arr[start];
            arr[start] = arr[end];
            arr[end] = temp;
            start++;
            end--;
        }
    for(int i = 0; i<n; i++){
        cout<<arr[i]<<" ";
        }
    }
};
int main(){
int arr[5] = {1, 2, 3, 4, 5};
int n = sizeof(arr) / sizeof(arr[0]);
Reverse  r;
r.Reverse_Array(arr, n);
return 0;
}

// PROBLEM 04 - Sum of array
// Task - sum between the elements of the array

#include<iostream>
using namespace std;

class Sum {
    public:
     int arr_sum(int arr[], int n){
        int sum = 0;
        for(int i = 0; i<n; i++){
            sum += arr[i];
        }
        return sum;
    }
};

int main(){
    int arr[5] = {1, 2, 3, 4, 5};
    // sizeof give ans in byte so here - 4bytes * 5 elements = 20 / 4byte = 5 elements
    int n = sizeof(arr) / sizeof(arr[0]);
    Sum s1;
    cout<<s1.arr_sum(arr, n);
return 0;
}