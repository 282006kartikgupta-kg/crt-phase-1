//  PROBLEM 01: FOR LOOP 
//  Task: print 1-n

#include<iostream>
using namespace std;

int main(){
int n;
cout<<"Enter number: ";
cin>>n;

for(int i = 1; i<=n; i++){
    cout<<i<<" ";
}
return 0;
}

//  PROBLEM 02: WHILE LOOP
//  Task: PRINT 1-10

#include<iostream>
using namespace std;

int main(){
int n;
cout<<"Enter number: ";
cin>>n;
int i = 1;
while(i<=n){
    cout<<i<<" ";
    i++;
}
return 0;
}

//  PROBLEM 03: DO WHILE LOOP
//  Task: PRINT 1-10

#include<iostream>
using namespace std;

int main(){
int n;
cout<<"Enter number: ";
cin>>n;
int i = 1;
do{
    cout<<i<<" ";
    i++;
}while (i<=n);
return 0;
}

//  PROBLEM 04: FACTORIAL CALCULATION
//  Task: take an input and print its factorial using for loop

#include<iostream>
using namespace std;

int main(){
int n;
cout<<"Enter number: ";
cin>>n;
int fact = 1;
for(int i = 1; i<=n; i++){
    fact *= i;
}
cout<<"Factorial : "<<fact<<endl;
return 0;
}

//  PROBLEM 05: FIBONACCI SEQUENCE
//  Task: take an input and print the fibonacci numbers till that input

#include<iostream>
using namespace std;

int main(){
int n;
cout<<"Enter number: ";
cin>>n;

int a = 0, b = 1, next;

for(int i = 1; i<=n; i++){
    cout<< a << " ";
    next = a + b;
    a = b;
    b = next;
}
return 0;
}

//  PROBLEM 06: PRIME CHECK
//  Task: take input and check if it is a prime no. or not

#include<iostream>
using namespace std;

int main(){
int n;
cout<<"Enter number: ";
cin>>n;

bool isPrime = true;

for(int i = 2; i < n; i++){
    if(n<=1){
    isPrime = false;
    break;
    }
    else if (n % i == 0){
        isPrime = false;
        break;
    }
}

if(isPrime){
    cout<< " it is a prime number";
} else {
    cout<<" it is not a prime number";
}
return 0;
}

