//  PROBLEM 04: USING POINTER
//  Task: WAP that applies 10% discount using reference update the cost

#include<iostream>
using namespace std;

//discount func
void discount(float &bill){
    bill = bill * 0.9;
    
}

int main(){
float bill;
cout<<"Enter bill: ";
cin>>bill;

discount(bill);
cout<<"Discounted Bill: "<<bill;

return 0;
}

//  PROBLEM 05: USING POINTER
//  Task: Swap two values


#include<iostream>
using namespace std;

void swapfunc(int &a, int &b){
    int *p1 = &a;
    int *p2 = &b;

    int temp = *p1;
    *p1 = *p2;
    *p2 = temp;
}

int main(){
int a , b;
cout<<"Enter numbers: ";
cin>>a>>b;

swapfunc(a,b);
cout<<a<<" "<<b;

return 0;
}